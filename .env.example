# ───────────────────────────────────────────────────────────────
# ConnectHub — environment variables template
# ───────────────────────────────────────────────────────────────
# Local dev: copy this file to `.env` and fill real values, then
#   docker-compose up
#
# Production (Render): set these as env vars in each service's
#   Render dashboard. Render reads them via ASP.NET Core's
#   double-underscore convention (e.g. ConnectionStrings__Default-
#   Connection becomes ConnectionStrings:DefaultConnection).
# ───────────────────────────────────────────────────────────────

# ── Auth (issued tokens shared across all services) ────────────
# 64-char hex secret. Same value MUST be set on every service.
JWT_KEY=

# ── Postgres (Neon) ────────────────────────────────────────────
# Pooled connection string. Same DB used by all services.
# Format: Host=...;Database=neondb;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10;
NEON_CONNECTION_STRING=

# ── Redis (Upstash) ────────────────────────────────────────────
# TLS Redis URL. Used by Hub.API as SignalR backplane.
# Format: rediss://default:TOKEN@HOST.upstash.io:6379
REDIS_CONNECTION_STRING=

# ── Cloudinary (Media.API) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth (Auth.API) ────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── SMTP (Notification.API) ────────────────────────────────────
SMTP_USERNAME=
SMTP_PASSWORD=
