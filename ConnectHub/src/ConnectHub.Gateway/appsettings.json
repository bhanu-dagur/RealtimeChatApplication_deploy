{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "",
    "Issuer": "ConnectHub",
    "Audience": "ConnectHubUsers",
    "DurationInMinutes": 60
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 5000
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "message-route": {
        "ClusterId": "message-cluster",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      },
      "room-route": {
        "ClusterId": "room-cluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        }
      },
      "hub-route": {
        "ClusterId": "hub-cluster",
        "Match": {
          "Path": "/api/presence/{**catch-all}"
        }
      },
      "notifications-signalr-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        }
      },
      "notifications-base-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications"
        }
      },
      "chat-signalr-route": {
        "ClusterId": "hub-cluster",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      },
      "chat-base-route": {
        "ClusterId": "hub-cluster",
        "Match": {
          "Path": "/hubs/chat"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "media-route": {
        "ClusterId": "media-cluster",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "HttpRequest": {
          "Version": "1.1",
          "Timeout": "00:01:40"
        },
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "message-cluster": {
        "HttpRequest": {
          "Version": "1.1",
          "Timeout": "00:01:40"
        },
        "Destinations": {
          "message-destination": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "room-cluster": {
        "HttpRequest": {
          "Version": "1.1",
          "Timeout": "00:01:40"
        },
        "Destinations": {
          "room-destination": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "hub-cluster": {
        "HttpRequest": {
          "Timeout": "00:01:40"
        },
        "Destinations": {
          "hub-destination": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "notification-cluster": {
        "HttpRequest": {
          "Version": "1.1",
          "Timeout": "00:01:40"
        },
        "Destinations": {
          "notification-destination": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "media-cluster": {
        "HttpRequest": {
          "Version": "1.1",
          "Timeout": "00:01:40"
        },
        "Destinations": {
          "media-destination": {
            "Address": "http://localhost:5006"
          }
        }
      }
    }
  }
}